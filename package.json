{
  "name": "yuanfang-music-player",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "generate:playlist": "node list-r2.cjs",
    "deploy:pages": "wrangler pages deploy . --project-name=yuanfang-music",
    "deploy:worker": "npm run worker:build && wrangler deploy worker/dist/worker.js --name music-proxy",
    "deploy:local": "powershell -File deploy.bat",
    "worker:build": "cd worker && npm run build",
    "worker:dev": "wrangler dev worker/src/index.ts",
    "clean": "node -e \"const fs=require('fs'); fs.rmSync('dist',{force:true,recursive:true})\"",
    "lint": "eslint src --ext .vue,.ts --fix",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "aplayer": "^1.10.1",
    "hls.js": "^1.5.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "@vueuse/core": "^10.9.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "happy-dom": "^14.0.0",
    "prettier": "^3.2.0",
    "sass": "^1.71.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0",
    "vitest": "^1.3.0",
    "vue-tsc": "^2.0.0",
    "wrangler": "^4.0.0"
  }
}
